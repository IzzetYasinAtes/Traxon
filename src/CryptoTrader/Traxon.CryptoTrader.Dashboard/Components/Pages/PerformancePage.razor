@page "/performance"
@rendermode InteractiveServer
@inject AdminDataService DataService

<div style="display: flex; flex-direction: column; height: calc(100vh - 50px); overflow: hidden; gap: 4px; padding: 4px;">
    <div style="flex-shrink: 0;">
        <h1 class="text-lg font-bold" style="margin: 0;">Performans Özeti</h1>
        <div style="font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 4px;">
            Genel sistem performans metrikleri. Kazanma oranı, toplam kar/zarar, Sharpe oranı ve motor bazlı karşılaştırma burada görüntülenir.
        </div>
    </div>

    @if (_summary == null)
    {
        <p class="text-sm" style="color: var(--color-text-muted);">Yükleniyor...</p>
    }
    else
    {
        <!-- Motor bazli KPI Kartlari - yan yana -->
        <div class="grid grid-cols-2 gap-2" style="flex-shrink: 0;">
            @foreach (var e in _summary.ByEngine)
            {
                var wr = e.Trades > 0 ? (decimal)e.Wins / e.Trades : 0;
                var pct = (e.TotalPnL / 50m) * 100m;
                <div>
                    <h2 style="font-size: 0.7rem; font-weight: 700; margin-bottom: 4px; color: var(--color-text-secondary);">@e.Engine</h2>
                    <div class="grid grid-cols-5 gap-1">
                        <StatCard Title="Bakiye" Value="@($"${50m + e.TotalPnL:N2}")" />
                        <StatCard Title="Kar/Zarar"
                                  Value="@($"{(e.TotalPnL >= 0 ? "+$" : "-$")}{Math.Abs(e.TotalPnL):N2}")"
                                  Color="@(e.TotalPnL >= 0 ? "var(--color-accent-green)" : "var(--color-accent-red)")" />
                        <StatCard Title="Kar %"
                                  Value="@($"{(pct >= 0 ? "+" : "")}{pct:F2}%")"
                                  Color="@(e.TotalPnL >= 0 ? "var(--color-accent-green)" : "var(--color-accent-red)")" />
                        <StatCard Title="Kazanma Oranı"
                                  Value="@($"{wr * 100:F1}%")"
                                  Color="@(wr >= 0.5m ? "var(--color-accent-green)" : "var(--color-accent-red)")" />
                        <StatCard Title="İşlem"
                                  Value="@e.Trades.ToString()"
                                  Subtitle="@($"{e.Wins} Kazanç")" />
                    </div>
                </div>
            }
        </div>

        <!-- Motor Karsilastirma Tablosu -->
        <div class="rounded-[8px] overflow-hidden"
             style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); flex-shrink: 0;">
            <div class="px-2 py-1" style="border-bottom: 1px solid var(--color-border-default);">
                <h2 style="font-size: 0.7rem; font-weight: 700; color: var(--color-text-secondary); margin: 0;">Motor Karşılaştırması</h2>
            </div>
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-xs" style="color: var(--color-text-muted);">
                        <th class="py-1 px-3 text-left">Motor</th>
                        <th class="py-1 px-3 text-right">İşlemler</th>
                        <th class="py-1 px-3 text-right">Kazanma Oranı</th>
                        <th class="py-1 px-3 text-right">Kar/Zarar</th>
                        <th class="py-1 px-3 text-right">Sharpe</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in _summary.ByEngine)
                    {
                        var wr = e.Trades > 0 ? (decimal)e.Wins / e.Trades : 0;
                        <tr style="border-top: 1px solid var(--color-border-default);">
                            <td class="py-1 px-3 font-mono text-xs"
                                style="color: var(--color-accent-purple);">@e.Engine</td>
                            <td class="py-1 px-3 text-right font-mono">@e.Trades</td>
                            <td class="py-1 px-3 text-right font-mono"
                                style="color: @(wr >= 0.5m ? "var(--color-accent-green)" : "var(--color-accent-red)")">@($"{wr * 100:F1}%")</td>
                            <td class="py-1 px-3 text-right font-mono"
                                style="color: @(e.TotalPnL >= 0 ? "var(--color-accent-green)" : "var(--color-accent-red)")">@($"{(e.TotalPnL >= 0 ? "+$" : "-$")}{Math.Abs(e.TotalPnL):N2}")</td>
                            <td class="py-1 px-3 text-right font-mono">@($"{e.Sharpe:F2}")</td>
                        </tr>
                    }
                    @if (_summary.ByEngine.Count == 0)
                    {
                        <tr><td colspan="5" class="py-4 text-center text-xs" style="color: var(--color-text-muted);">Veri bulunamadı</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Sermaye Egrisi -->
        <div class="rounded-[8px]" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); padding: 4px 8px; flex: 1 1 0; min-height: 0; overflow: hidden; display: flex; flex-direction: column;">
            <h2 style="font-size: 0.7rem; font-weight: 700; margin-bottom: 2px; color: var(--color-text-secondary); flex-shrink: 0;">Sermaye Eğrisi</h2>
            <div style="flex: 1 1 0; min-height: 0; overflow: hidden;">
                <AdminEquityChart Points="_equityPoints" Height="100%" />
            </div>
        </div>
    }
</div>

@code {
    private PerformanceSummary? _summary;
    private List<EquityPoint> _equityPoints = [];
    private decimal _totalInitialBalance;

    protected override async Task OnInitializedAsync()
    {
        _summary = await DataService.GetPerformanceSummaryAsync();
        _equityPoints = await DataService.GetEquityCurveAsync();

        // Calculate initial balance per engine from latest snapshot (Balance - TotalPnL)
        var engines = await DataService.GetEngineStatusAsync();
        _totalInitialBalance = engines.Sum(e => e.Balance - e.TotalPnL);
    }

    private string FormatPctPnl()
    {
        if (_summary is null || _totalInitialBalance == 0) return "0.00%";
        var pct = (_summary.TotalPnL / _totalInitialBalance) * 100m;
        return $"{(pct >= 0 ? "+" : "")}{pct:F2}%";
    }
}
