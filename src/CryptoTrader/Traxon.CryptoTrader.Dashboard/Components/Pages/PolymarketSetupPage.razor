        <div class="docs-step">
            <div class="docs-step-number">3</div>
            <div class="docs-step-content">
                <strong>Bagimliliklari kurun</strong>
                <pre class="docs-code">pip install -r D:\repos\Traxon\scripts\polymarket-signer\requirements.txt</pre>
                <p>veya:</p>
                <pre class="docs-code">python -m pip install -r D:\repos\Traxon\scripts\polymarket-signer\requirements.txt</pre>
            </div>
        </div>

