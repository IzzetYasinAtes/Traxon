@page "/portfolio"
@inject ILiveFeedService Feed
@inject Traxon.CryptoTrader.Application.Abstractions.IPolymarketSigningClient SigningClient
@implements IDisposable

<div class="flex flex-col gap-2" style="height: calc(100vh - 60px); overflow: hidden;">
    <div>
        <h1 class="text-lg font-bold" style="margin: 0;">Portföy</h1>
        <div style="font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 8px;">Her motor için anlık bakiye durumu ve kar/zarar performansı görüntülenir. Sermaye eğrisi, motorların zaman içindeki bakiye değişimini gösterir. Mavi çizgi PaperPoly, yeşil çizgi LivePoly motorunu temsil eder.</div>
    </div>

    <!-- Motor bazli kartlar - yan yana -->
    <div class="grid grid-cols-2 gap-2">
        @foreach (var (engine, portfolio) in Feed.Portfolios.Where(p => !p.Key.Contains("Binance", StringComparison.OrdinalIgnoreCase)))
        {
            <div>
                <h2 style="font-size: 0.7rem; font-weight: 700; margin-bottom: 4px; color: var(--color-text-secondary);">@engine</h2>
                <div class="grid grid-cols-5 gap-1">
                    <StatCard Title="Bakiye" Value="@($"${portfolio.Balance:N2}")" />
                    <StatCard Title="Toplam Kar/Zarar"
                              Value="@($"{(portfolio.TotalPnL >= 0 ? "+$" : "-$")}{Math.Abs(portfolio.TotalPnL):N2}")"
                              Color="@(portfolio.TotalPnL >= 0 ? "var(--color-accent-green)" : "var(--color-accent-red)")" />
                    <StatCard Title="Kar/Zarar %"
                              Value="@(FormatPctPnl(portfolio.TotalPnL, portfolio.InitialBalance))"
                              Color="@(portfolio.TotalPnL >= 0 ? "var(--color-accent-green)" : "var(--color-accent-red)")" />
                    <StatCard Title="Kazanma Oranı"
                              Value="@($"{portfolio.WinRate * 100:F1}%")"
                              Subtitle="@($"{portfolio.WinCount}W / {portfolio.LossCount}L")" />
                    <StatCard Title="Toplam İşlem"
                              Value="@portfolio.TotalTrades.ToString()"
                              Subtitle="@($"{portfolio.OpenPositionCount} açık")" />
                </div>
            </div>
        }
    </div>

    @if (Feed.Portfolios.Count == 0)
    {
        <div class="text-sm" style="color: var(--color-text-muted);">Portföy verisi bulunamadı</div>
    }

    <!-- Polymarket Cuzdan Bakiyesi -->
    @if (_walletBalance is not null)
    {
        <div class="rounded-[8px]" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); padding: 6px 12px; flex-shrink: 0;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <span style="font-size: 0.7rem; font-weight: 700; color: var(--color-text-secondary);">Polymarket Cuzdan (USDC)</span>
                <span style="font-size: 0.85rem; font-weight: 700; color: var(--color-accent-green);">$@(_walletBalance.Value.ToString("N2"))</span>
            </div>
        </div>
    }

    <!-- Sermaye Egrisi -->
    <div class="rounded-[8px]" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default); padding: 8px 12px; flex: 0.94 1 0; min-height: 0; overflow: hidden;">
        <h2 style="font-size: 0.7rem; font-weight: 700; margin-bottom: 4px; color: var(--color-text-secondary);">Sermaye Eğrisi</h2>
        <div style="height: calc(100% - 20px); overflow: hidden;">
            <EquityChart />
        </div>
    </div>
</div>

@code {
    private decimal? _walletBalance;

    protected override async Task OnInitializedAsync()
    {
        Feed.OnPortfolioUpdate += OnPortfolio;
        try
        {
            if (await SigningClient.IsHealthyAsync())
            {
                var result = await SigningClient.GetBalanceAsync();
                if (result.IsSuccess)
                    _walletBalance = result.Value;
            }
        }
        catch { /* Signing service aktif değilse sessizce geç */ }
    }

    private void OnPortfolio(PortfolioDto _) => InvokeAsync(StateHasChanged);
    public void Dispose() => Feed.OnPortfolioUpdate -= OnPortfolio;

    private static string FormatPctPnl(decimal totalPnl, decimal initialBalance)
    {
        const decimal fixedInitial = 50m;
        var pct = (totalPnl / fixedInitial) * 100m;
        return $"{(pct >= 0 ? "+" : "")}{pct:F2}%";
    }
}
