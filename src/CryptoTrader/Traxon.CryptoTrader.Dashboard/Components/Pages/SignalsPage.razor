@page "/signals"
@inject ILiveFeedService Feed
@inject IStringLocalizer<SharedResources> L
@implements IDisposable

<div>
    <div class="flex items-center justify-between mb-4">
        <h1 class="text-lg font-bold">@L["Signals"]</h1>
        <span class="text-sm" style="color: var(--color-text-muted);">@Feed.RecentSignals.Count @L["SignalsCount"]</span>
    </div>

    <!-- Filters -->
    <div class="flex gap-2 mb-4">
        @foreach (var dir in new[] { "ALL", "UP", "DOWN" })
        {
            <button @onclick="@(() => _filterDir = dir)"
                    class="px-3 py-1 rounded text-xs"
                    style="background-color: @(_filterDir == dir ? "rgba(0,212,170,0.15)" : "var(--color-bg-surface)");
                           color: @(_filterDir == dir ? "var(--color-accent-green)" : "var(--color-text-secondary)");
                           border: 1px solid var(--color-border-default);">
                @dir
            </button>
        }
    </div>

    <div class="grid grid-cols-4 gap-3">
        @foreach (var signal in FilteredSignals)
        {
            <SignalCard Signal="signal" />
        }
    </div>
</div>

@code {
    private string _filterDir = "ALL";

    private IEnumerable<SignalDto> FilteredSignals =>
        Feed.RecentSignals
            .Where(s => _filterDir == "ALL" || s.Direction == _filterDir)
            .OrderByDescending(s => s.GeneratedAt);

    protected override void OnInitialized() => Feed.OnSignalGenerated += OnSignal;
    private void OnSignal(SignalDto _) => InvokeAsync(StateHasChanged);
    public void Dispose() => Feed.OnSignalGenerated -= OnSignal;
}
