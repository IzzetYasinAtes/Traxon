@page "/"
@inject ILiveFeedService Feed
@implements IDisposable

<div class="flex flex-col gap-4">
    <!-- Portfoy Ozeti -->
    @if (Feed.Portfolios.Count > 0)
    {
        <section>
            <h2 class="text-sm font-bold mb-1" style="color: var(--color-text-secondary);">Portföy Özeti</h2>
            <div style="font-size: 0.7rem; color: var(--color-text-muted); margin-bottom: 8px;">
                Her motorun anlık bakiye, kar/zarar ve kazanma oranı
            </div>
            @foreach (var (engine, portfolio) in Feed.Portfolios)
            {
                <div class="mb-3">
                    <p class="text-xs mb-2" style="color: var(--color-text-muted);">@engine</p>
                    <div class="grid grid-cols-4 gap-3">
                        <StatCard Title="Bakiye" Value="@($"${portfolio.Balance:N2}")" />
                        <StatCard Title="Toplam Kar/Zarar"
                                  Value="@($"{(portfolio.TotalPnL >= 0 ? "+$" : "-$")}{Math.Abs(portfolio.TotalPnL):N2}")"
                                  Color="@(portfolio.TotalPnL >= 0 ? "var(--color-accent-green)" : "var(--color-accent-red)")" />
                        <StatCard Title="Kazanma Oranı"
                                  Value="@($"{portfolio.WinRate * 100:F1}%")"
                                  Subtitle="@($"{portfolio.WinCount}W / {portfolio.LossCount}L")" />
                        <StatCard Title="Toplam İşlem"
                                  Value="@portfolio.TotalTrades.ToString()"
                                  Subtitle="@($"{portfolio.OpenPositionCount} açık")" />
                    </div>
                </div>
            }
        </section>
    }

    <!-- Aktif Sinyaller -->
    <section>
        <h2 class="text-sm font-bold mb-1" style="color: var(--color-text-secondary);">Aktif Sinyaller</h2>
        <div style="font-size: 0.7rem; color: var(--color-text-muted); margin-bottom: 8px;">
            Son üretilen alım-satım sinyalleri. Yeşil = Yukarı, Kırmızı = Aşağı
        </div>
        <div class="grid grid-cols-4 gap-3">
            @foreach (var signal in Feed.RecentSignals.TakeLast(8).Reverse())
            {
                <SignalCard Signal="signal" />
            }
        </div>
    </section>

    <!-- Son Islemler -->
    <section>
        <h2 class="text-sm font-bold mb-1" style="color: var(--color-text-secondary);">Son İşlemler</h2>
        <div style="font-size: 0.7rem; color: var(--color-text-muted); margin-bottom: 8px;">
            En son açılan ve kapanan işlemler
        </div>
        <div class="rounded-[10px] overflow-hidden" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-xs" style="color: var(--color-text-muted); border-bottom: 1px solid var(--color-border-default);">
                        <th class="py-2 px-3 text-left">Sembol</th>
                        <th class="py-2 px-3 text-left">Yön</th>
                        <th class="py-2 px-3 text-left">Motor</th>
                        <th class="py-2 px-3 text-left">Giriş</th>
                        <th class="py-2 px-3 text-left">Kar/Zarar</th>
                        <th class="py-2 px-3 text-left">Durum</th>
                        <th class="py-2 px-3 text-left">Zaman</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trade in Feed.RecentTrades.TakeLast(10).Reverse())
                    {
                        <TradeRow Trade="trade" />
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    protected override void OnInitialized()
    {
        Feed.OnSignalGenerated += OnSignal;
        Feed.OnTradeOpened += OnTrade;
        Feed.OnTradeClosed += OnTrade;
        Feed.OnPortfolioUpdate += OnPortfolio;
    }

    private void OnSignal(SignalDto _) => InvokeAsync(StateHasChanged);
    private void OnTrade(TradeDto _) => InvokeAsync(StateHasChanged);
    private void OnPortfolio(PortfolioDto _) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Feed.OnSignalGenerated -= OnSignal;
        Feed.OnTradeOpened -= OnTrade;
        Feed.OnTradeClosed -= OnTrade;
        Feed.OnPortfolioUpdate -= OnPortfolio;
    }
}
