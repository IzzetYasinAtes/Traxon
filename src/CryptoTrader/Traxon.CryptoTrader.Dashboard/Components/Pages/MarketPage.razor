@page "/"
@inject ILiveFeedService Feed
@inject IStringLocalizer<SharedResources> L
@implements IDisposable

<div class="flex flex-col gap-4">
    <!-- Symbol + Interval selector -->
    <div class="flex items-center gap-3">
        <select @bind="_selectedSymbol" class="px-2 py-1 rounded text-sm"
                style="background-color: var(--color-bg-surface); color: var(--color-text-primary); border: 1px solid var(--color-border-default);">
            @foreach (var s in _symbols)
            {
                <option value="@s">@s.Replace("USDT", "")</option>
            }
        </select>
        @foreach (var tf in new[] { "1m", "5m", "15m" })
        {
            <button @onclick="@(() => _selectedInterval = tf)"
                    class="px-3 py-1 rounded text-xs"
                    style="background-color: @(_selectedInterval == tf ? "rgba(0,212,170,0.15)" : "var(--color-bg-surface)");
                           color: @(_selectedInterval == tf ? "var(--color-accent-green)" : "var(--color-text-secondary)");
                           border: 1px solid var(--color-border-default);">
                @tf
            </button>
        }
    </div>

    <!-- Chart (full width) -->
    <div>
        <CandlestickChart Symbol="@_selectedSymbol" Interval="@_selectedInterval" Height="420" />
    </div>

    <!-- Active Signals -->
    <section>
        <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-secondary);">@L["ActiveSignals"]</h2>
        <div class="grid grid-cols-4 gap-3">
            @foreach (var signal in Feed.RecentSignals.TakeLast(8).Reverse())
            {
                <SignalCard Signal="signal" />
            }
        </div>
    </section>

    <!-- Portfolio Overview -->
    @if (Feed.Portfolios.Count > 0)
    {
        <section>
            <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-secondary);">@L["PortfolioOverview"]</h2>
            @foreach (var (engine, portfolio) in Feed.Portfolios)
            {
                <div class="mb-3">
                    <p class="text-xs mb-2" style="color: var(--color-text-muted);">@engine</p>
                    <div class="grid grid-cols-4 gap-3">
                        <StatCard Title="@L["Balance"]" Value="@($"${portfolio.Balance:N2}")" />
                        <StatCard Title="@L["TotalPnL"]"
                                  Value="@($"{(portfolio.TotalPnL >= 0 ? "+$" : "-$")}{Math.Abs(portfolio.TotalPnL):N2}")"
                                  Color="@(portfolio.TotalPnL >= 0 ? "var(--color-accent-green)" : "var(--color-accent-red)")" />
                        <StatCard Title="@L["WinRate"]"
                                  Value="@($"{portfolio.WinRate * 100:F1}%")"
                                  Subtitle="@($"{portfolio.WinCount}W / {portfolio.LossCount}L")" />
                        <StatCard Title="@L["TotalTrades"]"
                                  Value="@portfolio.TotalTrades.ToString()"
                                  Subtitle="@($"{portfolio.OpenPositionCount} open")" />
                    </div>
                </div>
            }
        </section>
    }

    <!-- Recent Trades -->
    <section>
        <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-secondary);">@L["RecentTrades"]</h2>
        <div class="rounded-[10px] overflow-hidden" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-xs" style="color: var(--color-text-muted); border-bottom: 1px solid var(--color-border-default);">
                        <th class="py-2 px-3 text-left">@L["Symbol"]</th>
                        <th class="py-2 px-3 text-left">@L["Direction"]</th>
                        <th class="py-2 px-3 text-left">@L["Engine"]</th>
                        <th class="py-2 px-3 text-left">@L["Entry"]</th>
                        <th class="py-2 px-3 text-left">@L["PnL"]</th>
                        <th class="py-2 px-3 text-left">@L["Status"]</th>
                        <th class="py-2 px-3 text-left">@L["Time"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trade in Feed.RecentTrades.TakeLast(10).Reverse())
                    {
                        <TradeRow Trade="trade" />
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private string _selectedSymbol = "BTCUSDT";
    private string _selectedInterval = "1m";
    private readonly string[] _symbols = ["BTCUSDT", "ETHUSDT", "SOLUSDT", "XRPUSDT", "DOGEUSDT", "BNBUSDT", "HYPEUSDT"];

    protected override void OnInitialized()
    {
        Feed.OnSignalGenerated += OnSignal;
        Feed.OnTradeOpened += OnTrade;
        Feed.OnTradeClosed += OnTrade;
        Feed.OnPortfolioUpdate += OnPortfolio;
    }

    private void OnSignal(SignalDto _) => InvokeAsync(StateHasChanged);
    private void OnTrade(TradeDto _) => InvokeAsync(StateHasChanged);
    private void OnPortfolio(PortfolioDto _) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Feed.OnSignalGenerated -= OnSignal;
        Feed.OnTradeOpened -= OnTrade;
        Feed.OnTradeClosed -= OnTrade;
        Feed.OnPortfolioUpdate -= OnPortfolio;
    }
}
