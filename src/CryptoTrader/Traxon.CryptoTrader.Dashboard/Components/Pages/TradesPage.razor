@page "/trades"
@inject ILiveFeedService Feed
@implements IDisposable

<div>
    <h1 class="text-lg font-bold mb-1">İşlemler</h1>
    <div style="font-size: 0.7rem; color: var(--color-text-muted); margin-bottom: 8px;">
        Sistemin yaptığı tüm alım-satım işlemlerinin geçmişi. Durum ve motor bazlı filtreleme yapabilirsiniz. Açık işlemler henüz kapanmamış pozisyonları gösterir.
    </div>

    <!-- Sekmeler: Tumu | Acik | Kapali -->
    <div class="flex gap-2 mb-4">
        @foreach (var (tab, label) in new[] { ("ALL", "TÜMÜ"), ("OPEN", "AÇIK"), ("CLOSED", "KAPALI") })
        {
            <button @onclick="@(() => _activeTab = tab)"
                    class="px-4 py-1.5 rounded text-sm"
                    style="background-color: @(_activeTab == tab ? "rgba(0,212,170,0.15)" : "var(--color-bg-surface)");
                           color: @(_activeTab == tab ? "var(--color-accent-green)" : "var(--color-text-secondary)");
                           border: 1px solid var(--color-border-default);">
                @label
            </button>
        }
    </div>

    <!-- Motor Filtresi -->
    <div class="flex gap-2 mb-4">
        @foreach (var (engine, label) in new[] { ("ALL", "TÜMÜ"), ("PaperPoly", "PaperPoly"), ("PaperBinance", "PaperBinance") })
        {
            <button @onclick="@(() => _activeEngine = engine)"
                    class="px-4 py-1.5 rounded text-sm"
                    style="background-color: @(_activeEngine == engine ? "rgba(0,212,170,0.15)" : "var(--color-bg-surface)");
                           color: @(_activeEngine == engine ? "var(--color-accent-green)" : "var(--color-text-secondary)");
                           border: 1px solid var(--color-border-default);">
                @label
            </button>
        }
    </div>

    <div class="rounded-[10px] overflow-hidden" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-xs" style="color: var(--color-text-muted); border-bottom: 1px solid var(--color-border-default);">
                    <th class="py-2 px-3 text-left">Sembol</th>
                    <th class="py-2 px-3 text-left">Yön</th>
                    <th class="py-2 px-3 text-left">Motor</th>
                    <th class="py-2 px-3 text-left">Giriş</th>
                    <th class="py-2 px-3 text-left">Kar/Zarar</th>
                    <th class="py-2 px-3 text-left">Durum</th>
                    <th class="py-2 px-3 text-left">Zaman</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var trade in FilteredTrades)
                {
                    <TradeRow Trade="trade" />
                }
                @if (!FilteredTrades.Any())
                {
                    <tr>
                        <td colspan="7" class="py-8 text-center text-sm" style="color: var(--color-text-muted);">
                            Veri bulunamadı
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private string _activeTab = "ALL";
    private string _activeEngine = "ALL";

    private IEnumerable<TradeDto> FilteredTrades =>
        Feed.RecentTrades
            .Where(t => _activeTab == "ALL" || t.Status.Equals(_activeTab, StringComparison.OrdinalIgnoreCase))
            .Where(t => _activeEngine == "ALL" || t.Engine.Equals(_activeEngine, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(t => t.OpenedAt);

    protected override void OnInitialized()
    {
        Feed.OnTradeOpened += OnTrade;
        Feed.OnTradeClosed += OnTrade;
    }

    private void OnTrade(TradeDto _) => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Feed.OnTradeOpened -= OnTrade;
        Feed.OnTradeClosed -= OnTrade;
    }
}
