                    <td>6 x 5m = 30 dakika sonra force-close.</td>
                </tr>
                <tr>
                    <td><strong>Komisyon</strong></td>
                    <td><code>CommissionRate</code></td>
                    <td>%0.075 (0.00075)</td>
                    <td>Binance taker fee (BNB ile).</td>
                </tr>
                <tr>
                    <td><strong>Slippage</strong></td>
                    <td><code>SlippageRate</code></td>
                    <td>%0.05 (0.0005)</td>
                    <td>Emir kayma simulasyonu.</td>
                </tr>
                <tr>
                    <td><strong>Min Pozisyon</strong></td>
                    <td><code>MinPositionSize</code></td>
                    <td>$1</td>
