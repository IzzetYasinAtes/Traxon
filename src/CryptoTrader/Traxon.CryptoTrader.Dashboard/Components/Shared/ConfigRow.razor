<div class="flex items-start justify-between gap-4 py-2" style="border-bottom: 1px solid var(--color-border-subtle);">
    <div class="flex-1">
        <p class="text-sm">@Label</p>
        @if (!string.IsNullOrEmpty(Description))
        {
            <p class="text-xs mt-0.5" style="color: var(--color-text-muted);">@Description</p>
        }
    </div>
    <div class="w-36">
        @ChildContent
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
