<div style="display: flex; align-items: baseline; justify-content: space-between; padding: 3px 0; border-bottom: 1px solid var(--color-border-subtle);">
    <span style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-secondary); white-space: nowrap;">@Label</span>
    <span style="flex: 1; border-bottom: 1px dotted var(--color-border-subtle); margin: 0 8px; min-width: 20px;"></span>
    <span style="font-size: 0.9rem; font-family: monospace; color: var(--color-accent-emphasis); white-space: nowrap;">@Value</span>
    <span style="font-size: 0.7rem; color: var(--color-text-muted); margin-left: 8px; white-space: nowrap;">@Source</span>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Source { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
