@using ApexCharts

<ApexChart TItem="BrierBucket" Options="_options">
    <ApexPointSeries TItem="BrierBucket"
                     Items="Buckets"
                     Name="Tahmin %"
                     SeriesType="SeriesType.Bar"
                     XValue="@(b => b.Label)"
                     YValue="@(b => (decimal)(b.AvgPredicted * 100))" />
    <ApexPointSeries TItem="BrierBucket"
                     Items="Buckets"
                     Name="Gerçek Kazanma %"
                     SeriesType="SeriesType.Bar"
                     XValue="@(b => b.Label)"
                     YValue="@(b => (decimal)(b.ActualRate * 100))" />
</ApexChart>

@code {
    [Parameter] public List<BrierBucket> Buckets { get; set; } = [];

    private readonly ApexChartOptions<BrierBucket> _options = new()
    {
        Chart = new ApexCharts.Chart
        {
            Background = "#111111",
            ForeColor = "#888888",
            Toolbar = new Toolbar { Show = false }
        },
        Theme = new Theme { Mode = Mode.Dark },
        Grid = new Grid { BorderColor = "#1f1f1f" },
        Yaxis =
        [
            new YAxis
            {
                Min = 0,
                Max = 100,
                Labels = new YAxisLabels
                {
                    Formatter = "function(v) { return v.toFixed(0) + '%' }"
                }
            }
        ]
    };
}
