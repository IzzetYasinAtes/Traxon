@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<Traxon.CryptoTrader.Infrastructure.Persistence.AppDbContext> DbFactory
@inject IJSRuntime JS

<div style="width:100%; height:@(Height)px; background-color: var(--color-bg-surface); border-radius: var(--radius-card); overflow: hidden; position: relative;">
    <div id="@_chartId" style="width:100%; height:100%;"></div>
    @if (_candleDataJson is null)
    {
        <div style="position:absolute; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; color: var(--color-text-muted); font-size: 0.75rem;">
            Mum verisi bulunamadı
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Symbol { get; set; } = "BTCUSDT";
    [Parameter, EditorRequired] public string Interval { get; set; } = "1m";
    [Parameter] public int Height { get; set; } = 400;

    private readonly string _chartId = "chart" + Guid.NewGuid().ToString("N");
    private string? _candleDataJson;
    private string _prevKey = "";
    private bool _needsRender;

    protected override async Task OnParametersSetAsync()
    {
        var key = $"{Symbol}_{Interval}";
        if (key == _prevKey) return;
        _prevKey = key;

        await using var db = await DbFactory.CreateDbContextAsync();

        // Use FromSqlRaw to avoid owned entity LINQ translation issues
        var candles = await db.Candles
            .FromSqlRaw(
                "SELECT TOP 200 * FROM Candles WHERE Symbol = {0} AND [Interval] = {1} ORDER BY OpenTime DESC",
                Symbol, Interval)
            .ToListAsync();
        candles.Reverse();

        if (candles.Count > 0)
        {
            var data = candles.Select(c => new
            {
                time = new DateTimeOffset(c.OpenTime, TimeSpan.Zero).ToUnixTimeSeconds(),
                open = (float)c.Open,
                high = (float)c.High,
                low = (float)c.Low,
                close = (float)c.Close
            });
            _candleDataJson = System.Text.Json.JsonSerializer.Serialize(data);
        }
        else
        {
            _candleDataJson = null;
        }
        _needsRender = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsRender && _candleDataJson is not null)
        {
            _needsRender = false;
            await JS.InvokeVoidAsync("traxonCandlestickChart.render", _chartId, _candleDataJson, Height);
        }
    }
}
