@using Microsoft.EntityFrameworkCore
@using Microsoft.Data.SqlClient
@inject IDbContextFactory<Traxon.CryptoTrader.Infrastructure.Persistence.AppDbContext> DbFactory
@inject IJSRuntime JS

<div style="width:100%; height:100%; background-color: var(--color-bg-surface); border-radius: var(--radius-card); overflow: hidden; position: relative;">
    <div id="@_chartId" style="width:100%; height:100%;"></div>
    @if (_candleDataJson is null)
    {
        <div style="position:absolute; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; color: var(--color-text-muted); font-size: 0.75rem;">
            Mum verisi bulunamadı
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Symbol { get; set; } = "BTCUSDT";
    [Parameter, EditorRequired] public string Interval { get; set; } = "1m";
    [Parameter] public int Height { get; set; } = 400;

    private readonly string _chartId = "chart" + Guid.NewGuid().ToString("N");
    private string? _candleDataJson;
    private string _prevKey = "";
    private bool _needsRender;

    protected override async Task OnParametersSetAsync()
    {
        var key = $"{Symbol}_{Interval}";
        if (key == _prevKey) return;
        _prevKey = key;

        await using var db = await DbFactory.CreateDbContextAsync();
        var conn = db.Database.GetDbConnection();
        await conn.OpenAsync();

        await using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT TOP 200 OpenTime, [Open], High, Low, [Close] FROM Candles WHERE Symbol = @sym AND [Interval] = @tf ORDER BY OpenTime DESC";
        cmd.Parameters.Add(new SqlParameter("@sym", Symbol));
        cmd.Parameters.Add(new SqlParameter("@tf", Interval));

        var items = new List<object>();
        await using var reader = await cmd.ExecuteReaderAsync();
        while (await reader.ReadAsync())
        {
            var openTime = reader.GetDateTime(0);
            items.Add(new
            {
                time = new DateTimeOffset(openTime, TimeSpan.Zero).ToUnixTimeSeconds(),
                open = (double)reader.GetDecimal(1),
                high = (double)reader.GetDecimal(2),
                low = (double)reader.GetDecimal(3),
                close = (double)reader.GetDecimal(4)
            });
        }

        items.Reverse();

        if (items.Count > 0)
        {
            _candleDataJson = System.Text.Json.JsonSerializer.Serialize(items);
        }
        else
        {
            _candleDataJson = null;
        }
        _needsRender = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsRender && _candleDataJson is not null)
        {
            _needsRender = false;
            await JS.InvokeVoidAsync("traxonCandlestickChart.render", _chartId, _candleDataJson, Height);
        }
    }
}
