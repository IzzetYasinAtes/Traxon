@using Microsoft.AspNetCore.Components.Routing

<NavLink href="@Href" Match="@(Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)"
         class="flex items-center gap-3 px-4 py-3 mx-1 rounded-lg text-sm transition-colors no-underline"
         style="color: var(--color-text-secondary);"
         ActiveClass="nav-active">
    <span class="text-base flex-shrink-0">@Icon</span>
    <span class="opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">@Label</span>
</NavLink>

<style>
    .nav-active {
        color: var(--color-accent-green) !important;
        background-color: rgba(0, 212, 170, 0.1);
    }
</style>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "/";
    [Parameter, EditorRequired] public string Icon { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
}
