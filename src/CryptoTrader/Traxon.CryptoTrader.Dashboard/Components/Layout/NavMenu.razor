<nav class="flex-shrink-0 flex flex-col py-4 gap-1 w-14 hover:w-52 transition-all duration-300 overflow-hidden group"
     style="background-color: var(--color-bg-elevated); border-right: 1px solid var(--color-border-default);">

    <NavLinkItem Href="/" Icon="📊" Label="Genel Bakış" />
    <NavLinkItem Href="/portfolio" Icon="📈" Label="Portföy" />
    <NavLinkItem Href="/trades" Icon="📋" Label="İşlemler" />
    <NavLinkItem Href="/signals" Icon="📡" Label="Sinyaller" />
    <NavLinkItem Href="/performance" Icon="🏆" Label="Performans" />
    <NavLinkItem Href="/config" Icon="⚙️" Label="Yapılandırma" />
    <NavLinkItem Href="/logs" Icon="📝" Label="Loglar" />
    <NavLinkItem Href="/chart" Icon="📊" Label="Canlı Grafik" />

    <!-- Ayırıcı çizgi -->
    <div class="mx-3 my-2" style="border-top: 1px solid var(--color-border-default);"></div>

    <NavLinkItem Href="/guide" Icon="📚" Label="Finansal Rehber" />
    <NavLinkItem Href="/docs" Icon="🔬" Label="Teknik Dokümantasyon" />
    <NavLinkItem Href="/polymarket-setup" Icon="🔗" Label="Polymarket Kurulum" />
    <NavLinkItem Href="/livepoly-transition" Icon="🔄" Label="LivePoly Geçiş" />
    <NavLinkItem Href="/py-clob-client" Icon="🐍" Label="Python SDK Referans" />

    <div class="flex-1"></div>

    <!-- Sistem durumu -->
    @if (_status?.IsRunning == true)
    {
        <div class="flex items-center gap-2 px-4 py-2 text-xs" style="color: var(--color-text-muted);">
            <span class="w-2 h-2 rounded-full animate-pulse" style="background-color: var(--color-accent-green);"></span>
            <span class="opacity-0 group-hover:opacity-100 transition-opacity">Çalışıyor</span>
        </div>
    }
</nav>

@code {
    [Inject] ILiveFeedService Feed { get; set; } = default!;
    private SystemStatusDto? _status;

    protected override void OnInitialized()
    {
        _status = Feed.SystemStatus;
        Feed.OnSystemStatusUpdate += OnStatusUpdate;
    }

    private void OnStatusUpdate(SystemStatusDto s)
    {
        _status = s;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Feed.OnSystemStatusUpdate -= OnStatusUpdate;
}
