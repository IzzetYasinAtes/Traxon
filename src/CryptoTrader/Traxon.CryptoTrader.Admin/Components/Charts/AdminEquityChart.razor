@using ApexCharts

<ApexChart TItem="EquityPoint" Options="_options">
    @foreach (var engine in _series.Keys)
    {
        <ApexPointSeries TItem="EquityPoint"
                         Items="_series[engine]"
                         Name="@engine"
                         SeriesType="SeriesType.Area"
                         XValue="@(e => e.Timestamp.UtcDateTime)"
                         YValue="@(e => (decimal)e.Balance)" />
    }
</ApexChart>

@code {
    [Parameter] public List<EquityPoint> Points { get; set; } = [];

    private Dictionary<string, List<EquityPoint>> _series = new();

    private readonly ApexChartOptions<EquityPoint> _options = new()
    {
        Chart = new ApexCharts.Chart
        {
            Background = "#111111",
            ForeColor = "#888888",
            Toolbar = new Toolbar { Show = false }
        },
        Theme = new Theme { Mode = Mode.Dark },
        Stroke = new Stroke { Curve = Curve.Smooth, Width = [2] },
        Grid = new Grid
        {
            BorderColor = "#1f1f1f"
        },
        Xaxis = new XAxis
        {
            Type = XAxisType.Datetime,
            Labels = new XAxisLabels
            {
                DatetimeFormatter = new DatetimeFormatter
                {
                    Day = "dd MMM",
                    Hour = "HH:mm",
                    Minute = "HH:mm"
                }
            }
        }
    };

    protected override void OnParametersSet()
    {
        _series = Points
            .GroupBy(p => p.Engine)
            .ToDictionary(g => g.Key, g => g.ToList());
    }
}
