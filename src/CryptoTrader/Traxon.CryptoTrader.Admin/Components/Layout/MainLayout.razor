@inherits LayoutComponentBase

<div class="flex flex-col h-screen overflow-hidden"
     style="background-color: var(--color-bg-primary); color: var(--color-text-primary);">

    <header class="flex-shrink-0 h-12 flex items-center px-4 gap-4"
            style="background-color: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border-default);">
        <span class="text-sm font-bold tracking-wider"
              style="color: var(--color-accent-purple);">TRAXON ADMIN</span>
        <div class="flex-1"></div>
        <SystemStatusBadge />
    </header>

    <div class="flex flex-1 overflow-hidden">
        <NavMenu />
        <main class="flex-1 overflow-auto p-4">
            @Body
        </main>
    </div>
</div>
