@page "/logs"
@rendermode InteractiveServer
@inject AdminDataService DataService
@inject IStringLocalizer<SharedResources> L

<div class="flex flex-col gap-4">
    <div class="flex items-center justify-between">
        <h1 class="text-lg font-bold">@L["SystemLogs"]</h1>
        <button @onclick="RefreshAsync"
                style="background-color:var(--color-bg-surface); border:1px solid var(--color-border-default); color:var(--color-text-secondary); border-radius:6px; padding:4px 10px; font-size:12px; cursor:pointer;">@L["Refresh"]</button>
    </div>

    <!-- Level filter -->
    <div class="flex gap-2">
        @foreach (var lvl in new[] { "ALL", "INF", "WRN", "ERR" })
        {
            <button @onclick="@(() => { _levelFilter = lvl; })"
                    style="background-color:@(_levelFilter == lvl ? "rgba(168,85,247,0.15)" : "var(--color-bg-surface)"); border:1px solid @(_levelFilter == lvl ? "rgba(168,85,247,0.3)" : "var(--color-border-default)"); color:@(_levelFilter == lvl ? "var(--color-accent-purple)" : "var(--color-text-secondary)"); border-radius:6px; padding:3px 10px; font-size:12px; cursor:pointer;">@lvl</button>
        }
    </div>

    <!-- Log entries -->
    <div class="rounded-[10px] overflow-auto"
         style="max-height: 70vh; background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
        @foreach (var log in FilteredLogs)
        {
            <div class="px-4 py-1.5 font-mono text-xs flex gap-3"
                 style="border-bottom: 1px solid var(--color-border-subtle);">
                <span style="color: var(--color-text-muted); flex-shrink: 0;">@log.Timestamp.ToString("HH:mm:ss")</span>
                <span class="flex-shrink-0 font-bold w-8" style="color: @LevelColor(log.Level);">@log.Level</span>
                <span style="color: var(--color-text-secondary); word-break: break-all;">@log.Message</span>
            </div>
        }
        @if (FilteredLogs.Count == 0)
        {
            <p class="px-4 py-8 text-sm text-center" style="color: var(--color-text-muted);">@L["NoLogs"]</p>
        }
    </div>
</div>

@code {
    private List<AdminLogEntry> _logs = [];
    private string _levelFilter = "ALL";

    private List<AdminLogEntry> FilteredLogs => _levelFilter == "ALL"
        ? _logs
        : _logs.Where(l => l.Level.StartsWith(_levelFilter, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _logs = await DataService.GetRecentLogsAsync(200);
        _logs.Reverse(); // En yeni en uste
    }

    private static string LevelColor(string level) => level.ToUpperInvariant() switch
    {
        "ERR" or "FTL" => "var(--color-accent-red)",
        "WRN" => "var(--color-accent-gold)",
        "INF" => "var(--color-accent-blue)",
        _ => "var(--color-text-muted)"
    };
}
