@page "/calibration"
@rendermode InteractiveServer
@inject AdminDataService DataService

<div class="flex flex-col gap-6">
    <h1 class="text-lg font-bold">Kalibrasyon Analizi</h1>
    <div style="font-size: 0.7rem; color: var(--color-text-muted); margin-bottom: 8px;">
        Sinyal doğruluğu ve parametre kalibrasyonu
    </div>

    <!-- Aciklama -->
    <div class="rounded-[10px] p-4" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
        <h2 class="text-sm font-bold mb-2" style="color: var(--color-text-secondary);">Kalibrasyon Nedir?</h2>
        <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">
            Kalibrasyon, modelin tahmin ettiği kazanma olasılıklarının gerçek sonuçlarla ne kadar uyumlu olduğunu ölçer.
            İşlemler olasılık aralıklarına gruplandırılır (ör. %50-%60). Model bir grup için %55 kazanma oranı tahmin edip
            gerçekte %54 kazanıyorsa, model o aralık için iyi kalibre edilmiş demektir.
            <strong style="color: var(--color-text-secondary);">Brier Skoru</strong> genel doğruluğu ölçer:
            0 = mükemmel tahmin, 0.25 = rastgele tahmin. Düşük olan daha iyidir.
        </p>
    </div>

    <div class="grid grid-cols-2 gap-4">
        <!-- Grafik -->
        <div class="rounded-[10px] p-4"
             style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
            <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-secondary);">Tahmin ve Gerçek Kazanma Oranı</h2>
            @if (_buckets.Count > 0)
            {
                <CalibrationBucketChart Buckets="_buckets" />
            }
            else
            {
                <p class="text-sm" style="color: var(--color-text-muted);">Yeterli işlem verisi yok</p>
            }
        </div>

        <!-- Kalibrasyon Araliklari Tablosu -->
        <div class="rounded-[10px] p-4"
             style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
            <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-secondary);">Kalibrasyon Aralıkları</h2>

            @if (_buckets.Count == 0)
            {
                <p class="text-sm" style="color: var(--color-text-muted);">Veri bulunamadı</p>
            }
            else
            {
                <table class="w-full text-xs">
                    <thead>
                        <tr style="color: var(--color-text-muted);">
                            <th class="py-1 text-left">Aralık</th>
                            <th class="py-1 text-right">Tahmin</th>
                            <th class="py-1 text-right">Gerçek</th>
                            <th class="py-1 text-right">Adet</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _buckets)
                        {
                            var diff = b.ActualRate - b.AvgPredicted;
                            <tr style="border-top: 1px solid var(--color-border-default);">
                                <td class="py-1 font-mono" style="color: var(--color-text-secondary);">@b.Label</td>
                                <td class="py-1 text-right font-mono">@($"{b.AvgPredicted:P1}")</td>
                                <td class="py-1 text-right font-mono"
                                    style="color: @(Math.Abs(diff) < 0.05 ? "var(--color-accent-green)" : "var(--color-accent-red)")">
                                    @($"{b.ActualRate:P1}")
                                </td>
                                <td class="py-1 text-right font-mono" style="color: var(--color-text-muted);">@b.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="mt-4 pt-3" style="border-top: 1px solid var(--color-border-default);">
                    <p class="text-xs" style="color: var(--color-text-muted);">Brier Skoru</p>
                    <p class="text-2xl font-mono font-bold mt-1"
                       style="color: @(_brierScore < 0.25 ? "var(--color-accent-green)" : "var(--color-accent-red)")">@($"{_brierScore:F4}")</p>
                    <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                        @(_brierScore < 0.25 ? "İyi kalibre edilmiş" : "Kalibrasyon gerekli")
                        (0=Mükemmel, 0.25=Rastgele)
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<BrierBucket> _buckets = [];
    private double _brierScore;

    protected override async Task OnInitializedAsync()
    {
        _buckets = await DataService.GetBrierBucketsAsync();
        var points = await DataService.GetCalibrationDataAsync();
        if (points.Count > 0)
            _brierScore = points.Average(p => Math.Pow(p.Predicted - p.Actual, 2));
    }
}
