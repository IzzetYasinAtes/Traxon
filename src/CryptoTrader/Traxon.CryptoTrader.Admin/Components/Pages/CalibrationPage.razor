@page "/calibration"
@rendermode InteractiveServer
@inject AdminDataService DataService
@inject IStringLocalizer<SharedResources> L

<div class="flex flex-col gap-6">
    <h1 class="text-lg font-bold">@L["CalibrationAnalysis"]</h1>

    <!-- Explanation -->
    <div class="rounded-[10px] p-4" style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
        <h2 class="text-sm font-bold mb-2" style="color: var(--color-text-secondary);">What is Calibration?</h2>
        <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">
            Calibration measures how well the model's predicted win probabilities match actual outcomes.
            Trades are grouped into probability bins (e.g. 50%-60%). If the model predicts 55% win rate for a group
            and 54% actually win, the model is well-calibrated for that range.
            <strong style="color: var(--color-text-secondary);">Brier Score</strong> quantifies overall accuracy:
            0 = perfect predictions, 0.25 = random guessing. Lower is better.
        </p>
    </div>

    <div class="grid grid-cols-2 gap-4">
        <!-- Bar Chart -->
        <div class="rounded-[10px] p-4"
             style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
            <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-secondary);">@L["PredictedVsActualWinRate"]</h2>
            @if (_buckets.Count > 0)
            {
                <CalibrationBucketChart Buckets="_buckets" />
            }
            else
            {
                <p class="text-sm" style="color: var(--color-text-muted);">@L["NoDataMinTrades"]</p>
            }
        </div>

        <!-- Calibration Bins Table -->
        <div class="rounded-[10px] p-4"
             style="background-color: var(--color-bg-surface); border: 1px solid var(--color-border-default);">
            <h2 class="text-sm font-bold mb-3" style="color: var(--color-text-secondary);">@L["CalibrationBins"]</h2>

            @if (_buckets.Count == 0)
            {
                <p class="text-sm" style="color: var(--color-text-muted);">@L["NoData"]</p>
            }
            else
            {
                <table class="w-full text-xs">
                    <thead>
                        <tr style="color: var(--color-text-muted);">
                            <th class="py-1 text-left">@L["Bin"]</th>
                            <th class="py-1 text-right">@L["Predicted"]</th>
                            <th class="py-1 text-right">@L["Actual"]</th>
                            <th class="py-1 text-right">@L["Count"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in _buckets)
                        {
                            var diff = b.ActualRate - b.AvgPredicted;
                            <tr style="border-top: 1px solid var(--color-border-default);">
                                <td class="py-1 font-mono" style="color: var(--color-text-secondary);">@b.Label</td>
                                <td class="py-1 text-right font-mono">@($"{b.AvgPredicted:P1}")</td>
                                <td class="py-1 text-right font-mono"
                                    style="color: @(Math.Abs(diff) < 0.05 ? "var(--color-accent-green)" : "var(--color-accent-red)")">
                                    @($"{b.ActualRate:P1}")
                                </td>
                                <td class="py-1 text-right font-mono" style="color: var(--color-text-muted);">@b.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="mt-4 pt-3" style="border-top: 1px solid var(--color-border-default);">
                    <p class="text-xs" style="color: var(--color-text-muted);">@L["BrierScore"]</p>
                    <p class="text-2xl font-mono font-bold mt-1"
                       style="color: @(_brierScore < 0.25 ? "var(--color-accent-green)" : "var(--color-accent-red)")">@($"{_brierScore:F4}")</p>
                    <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                        @(_brierScore < 0.25 ? L["WellCalibrated"] : L["NeedsCalibration"])
                        (0=Mukemmel, 0.25=Random)
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<BrierBucket> _buckets = [];
    private double _brierScore;

    protected override async Task OnInitializedAsync()
    {
        _buckets = await DataService.GetBrierBucketsAsync();
        var points = await DataService.GetCalibrationDataAsync();
        if (points.Count > 0)
            _brierScore = points.Average(p => Math.Pow(p.Predicted - p.Actual, 2));
    }
}
