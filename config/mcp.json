{
  "mcpServers": {
    "traxon": {
      "command": "dotnet",
      "args": ["run", "--project", "src/ClaudeOrchestrator/Traxon.Mcp"],
      "env": {
        "TRAXON_WORKSPACE": "./workspace",
        "TRAXON_DB_CONNECTION": "Server=(localdb)\\MSSQLLocalDB;Database=TrAxonCryptoTrader;Trusted_Connection=True;TrustServerCertificate=True"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    }
  }
}
